# ============================================================================
# TiffinCRM Backend Configuration (.env)
# ============================================================================
# Copy this file to .env and fill in your API keys
# IMPORTANT: Never commit .env to git (add to .gitignore)
# ============================================================================

# ============================================================================
# DATABASE
# ============================================================================
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/tiffincrm

# ============================================================================
# SERVER
# ============================================================================
PORT=5000
NODE_ENV=development

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate random 32+ character strings for these
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_random_access_secret_here_generate_with_crypto_min_32_chars
JWT_REFRESH_SECRET=your_random_refresh_secret_here_generate_with_crypto_min_32_chars
# Optional: token expiry (default 15m access, 7d refresh)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================================
# FIREBASE CLOUD MESSAGING (FCM) - FOR PUSH NOTIFICATIONS
# ============================================================================
# Setup: https://console.firebase.google.com
# 1. Create/Select Project → Project Settings → Service Accounts
# 2. Click "Generate new private key" → Download JSON
# 3. Extract these fields from the JSON download

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyHereWithBackslashN\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ============================================================================
# MSG91 SMS & OTP SERVICE
# ============================================================================
# Setup: https://www.msg91.com
# 1. Create free account
# 2. Get AUTH_KEY from dashboard
# 3. Create OTP template → Get TEMPLATE_ID
# Cost: ₹0.50-2 per SMS

MSG91_AUTH_KEY=your_msg91_auth_key_from_dashboard
MSG91_TEMPLATE_ID=your_msg91_template_id_from_otp_templates

# ============================================================================
# RAZORPAY - PAYMENT PROCESSING
# ============================================================================
# Setup: https://razorpay.com
# 1. Create account
# 2. Get keys from Settings → API Keys (Test/Live)
# 3. Create webhook from Settings → Webhooks
# Cost: 2% transaction fee (free during testing with test keys)

RAZORPAY_KEY_ID=key_test_xxxxx_or_key_live_xxxxx
RAZORPAY_KEY_SECRET=secret_test_xxxxx_or_secret_live_xxxxx
RAZORPAY_WEBHOOK_SECRET=webhook_secret_from_webhooks_section

# ============================================================================
# CLOUDINARY - FILE & INVOICE STORAGE
# ============================================================================
# Setup: https://cloudinary.com
# 1. Create account → Dashboard
# 2. Get Cloud Name, API Key, API Secret
# Cost: FREE 25GB storage

CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ============================================================================
# SENDGRID - EMAIL SERVICE (ADD DURING WEEK 1 DAY 5)
# ============================================================================
# Setup: https://sendgrid.com
# 1. Create account → API Keys → Create API Key (Mail Send)
# 2. Create & verify sender email
# Cost: FREE 100 emails/day

SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=noreply@tiffincrm.com

# ============================================================================
# TWILIO - WHATSAPP & SMS SERVICE (ADD DURING WEEK 2 DAY 6)
# ============================================================================
# Setup: https://www.twilio.com
# 1. Create account → Console → Get Account SID & Auth Token
# 2. Enable WhatsApp Sandbox (Messaging → Try it out)
# 3. Get Twilio WhatsApp Number
# Cost: FREE $15 trial, then pay-as-you-go

TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# Twilio Verify Service SID — required for OTP (from Console → Verify → Services)
TWILIO_SERVICE_SID=VA_your_verify_service_sid_here
TWILIO_PHONE_NUMBER=+1234567890_your_twilio_sms_number
TWILIO_WHATSAPP_NUMBER=+14155552671_or_your_whatsapp_number

# ============================================================================
# GOOGLE MAPS API - ROUTE OPTIMIZATION (ADD DURING WEEK 3 DAY 11)
# ============================================================================
# Setup: https://console.cloud.google.com
# 1. Create Project → APIs & Services → Credentials
# 2. Create API Key → Enable: Maps JavaScript, Directions, Distance Matrix
# Cost: FREE $200/month credit

GOOGLE_MAPS_API_KEY=AIzaSy_your_google_maps_api_key_here

# ============================================================================
# TRUECALLER - ALTERNATIVE AUTHENTICATION (OPTIONAL - ADD WEEK 1 DAY 3)
# ============================================================================
# Setup: https://developer.truecaller.com
# 1. Register business account
# 2. Apply for API access (may take 1-2 days)
# 3. Get API Key once approved
# Cost: FREE

# Legacy verify API (optional if you only use OAuth PKCE below)
TRUECALLER_API_KEY=your_truecaller_api_key_here
# Required for Flutter OAuth PKCE — same Client Id as Android manifest / client .env TRUECALLER_CLIENT_ID
TRUECALLER_CLIENT_ID=
# Optional overrides (defaults: oauth-account-noneu.truecaller.com)
# TRUECALLER_OAUTH_TOKEN_URL=https://oauth-account-noneu.truecaller.com/v1/token
# TRUECALLER_OAUTH_USERINFO_URL=https://oauth-account-noneu.truecaller.com/v1/userinfo
# Dev only: skip real Truecaller calls
# TRUECALLER_MOCK=true

# ============================================================================
# SENTRY - ERROR MONITORING (OPTIONAL - ADD WEEK 7)
# ============================================================================
# Setup: https://sentry.io
# 1. Create account → New Project (Node.js)
# 2. Copy DSN (Data Source Name)
# Cost: FREE 1GB events/month

SENTRY_DSN=https://your_key@your_id.ingest.sentry.io/your_project_id

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:3000
FRONTEND_PRODUCTION_URL=https://app.tiffincrm.com
# Allowed CORS origin for REST API and Socket.IO in production (comma-separated or single URL)
CORS_ORIGIN=https://app.tiffincrm.com

# ============================================================================
# RATE LIMITING (Optional)
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_MESSAGE=Too many requests, please try again later.

# ============================================================================
# BUSINESS LOGIC DEFAULTS
# ============================================================================
# Wallet balance threshold below which low-balance alerts are sent (in ₹)
# Overridden per-vendor via User.settings.lowBalanceThreshold
LOW_BALANCE_THRESHOLD=100
